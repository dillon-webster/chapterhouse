# ---------------------------------------------------------------------------
# Chapterhouse — environment configuration
# Copy to `.env` for local dev. In production these are set via docker-compose.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Local dev (Postgres on host):   postgresql://postgres:postgres@localhost:5432/chapterhouse
# Docker compose (service name):  postgresql://postgres:postgres@db:5432/chapterhouse
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chapterhouse"

# NextAuth (Auth.js) secret — used to sign/encrypt session JWTs.
# In Docker this is optional (auto-generated and persisted on first boot).
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-with-openssl-rand-base64-32"

# Base URL of the app. In production set to your server's URL.
AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
# Absolute path to the directory where EPUBs, cover images, and avatars live.
# On a server this typically points at a large host directory that is
# bind-mounted into the container at /data (see docker-compose.yml).
#   Local dev:  ./storage  (created automatically, gitignored)
#   Server:     /data
STORAGE_DIR="./storage"

# ---------------------------------------------------------------------------
# Bootstrap (consumed only by `npm run db:seed` — optional dev convenience;
# normally the first-run setup wizard at /setup creates the admin account)
# ---------------------------------------------------------------------------
# Initial admin account created on first seed.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-too"
SEED_ADMIN_DISPLAY_NAME="Admin"

# Initial shared invite code handed out to friends to self-register.
SEED_INVITE_CODE="FIRST-CLUB-INVITE"
